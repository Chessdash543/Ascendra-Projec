        function swingSword() {
            if(isSilenced) return; playSound('sword');
            targetSwordRotX = -Math.PI; setTimeout(() => { targetSwordRotX = -Math.PI / 4; }, 200);
            const pPos = controls.getObject().position; const pDir = new THREE.Vector3(); camera.getWorldDirection(pDir);
            let damageDealtNow = 0;
            
            const checkHit = (enemy, dmg) => {
                const vecToEnemy = new THREE.Vector3().subVectors(enemy.position, pPos);
                if (vecToEnemy.length() < 120) { 
                    if (vecToEnemy.normalize().angleTo(pDir) < Math.PI / 2.0) { 
                        if(enemy === bossGroup) { 
                            if(!bossShielded && !bossDisappeared) { 
                                bossHealth -= dmg; damageDealtNow += dmg; flashBoss(); 
                                if (bossHealth <= 0 && !bossExploding) { triggerBossExplosion(); bossExploding = true; }
                            } 
                        } 
                        else {
                            enemy.userData.hp -= (dmg / 50); flashRobot(enemy);
                            if (enemy.userData.hp <= 0) { scene.remove(enemy); minions = minions.filter(m => m !== enemy); }
                        }
                    }
                }
            };
            
            checkHit(bossGroup, isFrenzy? 600 : 300); minions.forEach(m => checkHit(m, 300));
            
            if(damageDealtNow > 0 && !bossShielded && !bossDisappeared) {
                swordDamageDealt += damageDealtNow; document.getElementById('ultBar').style.width = Math.min(100, (swordDamageDealt / swordMaxDamage) * 100) + '%';
                if(swordDamageDealt >= swordMaxDamage) { swordDamageDealt = 0; document.getElementById('ultBar').style.width = '0%'; fireOrbitalStrike(); }
            }
            updateUI();
        }

        function fireOrbitalStrike() {
            playSound('orbital');
            const laser = new THREE.Mesh(new THREE.CylinderGeometry(15, 15, 400, 32), new THREE.MeshBasicMaterial({ color: 0x00ffff, transparent: true, opacity: 0.9, blending: THREE.AdditiveBlending }));
            laser.position.copy(bossGroup.position); laser.position.y = 200;
            scene.add(laser); lasers.push({ mesh: laser, life: 1.5 });
            bossHealth -= 5000; updateUI(); flashBoss();
            if (bossHealth <= 0 && !bossExploding) { triggerBossExplosion(); bossExploding = true; }
        }

        const raycaster = new THREE.Raycaster();
        function createHit(range, damage, isMelee, isSuperBlaster = false) {
            raycaster.setFromCamera(new THREE.Vector2(0, 0), camera);
            
            let checkList = [bossCore, ring1, ring2];
            if (bossShielded) checkList.push(shieldVisual); // Escudo só tem hitbox física se existir lacaios
            minions.forEach(m => checkList.push(m.children[0], m.children[1]));
            
            const intersects = raycaster.intersectObjects(checkList);
            let origin = isAiming ? camera.getWorldPosition(new THREE.Vector3()) : gunBarrel.getWorldPosition(new THREE.Vector3());
            const pts = [origin, new THREE.Vector3()]; raycaster.ray.at(range, pts[1]);
            
            if (intersects.length > 0 && intersects[0].distance <= range) pts[1] = intersects[0].point;
            
            if (isSuperBlaster) {
                const dist = pts[0].distanceTo(pts[1]);
                const cyl = new THREE.Mesh(new THREE.CylinderGeometry(4, 4, dist, 16), new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.9 }));
                cyl.position.copy(pts[0]).lerp(pts[1], 0.5); cyl.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), pts[1].clone().sub(pts[0]).normalize());
                scene.add(cyl); lasers.push({ mesh: cyl, life: 0.5 });
            } else {
                const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: isFrenzy? 0xff0000 : 0xffaa00, linewidth: 5 }));
                scene.add(line); lasers.push({ mesh: line, life: 0.08 });
            }

            if (intersects.length > 0 && intersects[0].distance <= range) {
                consecutiveHits++; const hit = intersects[0].object;
                if (hit === bossCore || hit === ring1 || hit === ring2 || hit === shieldVisual) {
                    if(!bossShielded && !bossDisappeared) { 
                        bossHealth -= damage; updateUI(); flashBoss(); 
                        if (bossHealth <= 0 && !bossExploding) { triggerBossExplosion(); bossExploding = true; }
                    }
                } else {
                    const robot = hit.parent;
                    if(robot && robot.userData.isRobot) {
                        robot.userData.hp -= (damage / 100); flashRobot(robot);
                        if (robot.userData.hp <= 0) { scene.remove(robot); minions = minions.filter(m => m !== robot); }
                    }
                }
            } else {
                consecutiveHits = 0; 
            }
        }

        function flashBoss() { bossCore.material.emissive.setHex(0xffffff); setTimeout(() => bossCore.material.emissive.setHex(phase66 ? 0x330000 : 0x000000), 80); }
        function flashRobot(rob) { rob.children.forEach(c => { if(c.material.emissive) c.material.emissive.setHex(0xffffff); }); setTimeout(() => { rob.children.forEach(c => { if(c.material.emissive && c.geometry.type !== 'SphereGeometry') c.material.emissive.setHex(0x000000); }); }, 80); }
        function reloadWeapon() { if (isReloading || ammo === maxAmmo || isSilenced) return; isReloading = true; document.getElementById('ammoText').innerText = "Rec..."; if(!isAiming) targetGunRotX = Math.PI / 2; setTimeout(() => { ammo = maxAmmo; isReloading = false; if(!isAiming) targetGunRotX = 0; updateAmmoUI(); }, isFrenzy? 600:1200); }
        function switchWeapon(type) { if(isSilenced) return; currentWeapon = type; if(type === 'gun') { if(!isAiming) gunGroup.visible = true; swordGroup.visible = false; document.getElementById('weaponText').innerText = "Pistola"; } else { gunGroup.visible = false; swordGroup.visible = true; if(isAiming) { isAiming=false; document.getElementById('scopeOverlay').style.opacity = 0; camera.fov = 75; camera.updateProjectionMatrix(); } document.getElementById('weaponText').innerText = "Espada"; } }
        function updateAmmoUI() { document.getElementById('ammoText').innerText = ammo; document.getElementById('comboText').innerText = consecutiveHits; document.getElementById('comboText').style.color = consecutiveHits > 0 ? '#ffaa00' : '#fff'; }

        let canJump = false; let playerBaseY = 10;
        
        const onKeyDown = function (e) {
            if (!controls.isLocked || gameOver) return;
            switch (e.code) {
                case 'KeyW': moveForward = true; break; case 'KeyA': moveLeft = true; break;
                case 'KeyS': moveBackward = true; break; case 'KeyD': moveRight = true; break;
                case 'Space': if (canJump) { velocity.y += (isFrenzy? 300 : 220); canJump = false; } break;
                case 'KeyR': reloadWeapon(); break; case 'Digit1': switchWeapon('gun'); break; case 'Digit2': switchWeapon('sword'); break;
                case 'KeyE': useDash(); break; case 'KeyQ': useAbility(); break; case 'KeyF': toggleLantern(); break;
            }
        };
        const onKeyUp = function (e) { switch (e.code) { case 'KeyW': moveForward = false; break; case 'KeyA': moveLeft = false; break; case 'KeyS': moveBackward = false; break; case 'KeyD': moveRight = false; break; } };
        document.addEventListener('keydown', onKeyDown); document.addEventListener('keyup', onKeyUp);

        function toggleLantern() { lanternOn = !lanternOn; playerLight.intensity = lanternOn ? 1.5 : 0; document.getElementById('lanternStatus').innerHTML = `Lanterna [F]: <span style="color:${lanternOn?'#00ffff':'#ff0000'}">${lanternOn?'Ligada':'Desligada'}</span>`; }
        function useDash() { if (dashCooldown > 0 || isSilenced) return; const dir = new THREE.Vector3(); camera.getWorldDirection(dir); dir.y = 0; dir.normalize(); controls.getObject().position.addScaledVector(dir, 100); dashCooldown = 3.0; updateSkillUI(); }
        function useAbility() {
            if (abilityCooldown > 0 || isSilenced || selectedAbility === 'frenzy') return;
            if (selectedAbility === 'corredor') { runnerTimer = 10.0; abilityCooldown = 20.0; } 
            else if (selectedAbility === 'jump') { velocity.y += 450; abilityCooldown = 10.0; canJump=false;} 
            else if (selectedAbility === 'heavy') { if (ammo < 5) return; ammo -= 5; updateAmmoUI(); createHit(800, 3000, false, true); abilityCooldown = 7.0; } 
            else if (selectedAbility === 'heal') { playerHealth = Math.min(maxPlayerHealth, playerHealth + 60); updateUI(); document.getElementById('healOverlay').style.opacity = 1; setTimeout(() => document.getElementById('healOverlay').style.opacity = 0, 400); abilityCooldown = 15.0; }
            updateSkillUI();
        }
        function updateSkillUI() { document.getElementById('dashStatus').innerHTML = `Dash [E]: ` + (dashCooldown > 0 ? `${Math.ceil(dashCooldown)}s` : `<span class="skill-ready">Pronto</span>`); document.getElementById('abilityStatus').innerHTML = `Habilidade [Q]: ` + (abilityCooldown > 0 ? `${Math.ceil(abilityCooldown)}s` : `<span class="skill-ready">Pronta</span>`); }
        function takeDamage(amount) {
            if(gameOver) return; playerHealth -= amount;
            document.getElementById('damageOverlay').style.opacity = 1; setTimeout(() => document.getElementById('damageOverlay').style.opacity = 0, 150);
            updateUI(); const dir = new THREE.Vector3(); camera.getWorldDirection(dir); controls.getObject().position.addScaledVector(dir, -5);
            if (playerHealth <= 0) { gameOver = true; controls.unlock(); document.getElementById('instructions').innerHTML = "<h1 style='color: red; font-size: 50px;'>A NOITE VENCEU</h1><button class='btn' onclick='location.reload()'>Tentar Novamente</button>"; }
        }
        function updateUI() { document.getElementById('playerHpText').innerText = Math.max(0, Math.floor(playerHealth)); document.getElementById('playerHealthBar').style.width = Math.max(0, (playerHealth / maxPlayerHealth) * 100) + '%'; document.getElementById('bossHealthBar').style.width = Math.max(0, (bossHealth / maxBossHealth) * 100) + '%'; }

        controls.getObject().position.set(0, 10, 200);

        function animate() {
            requestAnimationFrame(animate);
            const time = performance.now(); const delta = (time - prevTime) / 1000;

            gunGroup.position.lerp(targetGunPos, 15 * delta); gunGroup.rotation.x = THREE.MathUtils.lerp(gunGroup.rotation.x, targetGunRotX, 15 * delta); swordGroup.rotation.x = THREE.MathUtils.lerp(swordGroup.rotation.x, targetSwordRotX, 15 * delta);

            if (controls.isLocked && !gameOver) {
                const pos = controls.getObject().position;
                isFrenzy = (selectedAbility === 'frenzy' && playerHealth < 30); document.getElementById('frenzyWarning').style.display = isFrenzy ? 'block' : 'none';
                regenTimer += delta; if (regenTimer >= 2.0 && playerHealth > 0 && playerHealth < maxPlayerHealth) { playerHealth = Math.min(maxPlayerHealth, playerHealth + 3.0); updateUI(); regenTimer = 0; }
                if (isSilenced) { silenceTimer -= delta; document.getElementById('silenceText').innerText = `SILENCIADO! (${Math.ceil(silenceTimer)}s)`; if (silenceTimer <= 0) { isSilenced = false; document.getElementById('silenceOverlay').style.opacity = 0; document.getElementById('silenceText').style.opacity = 0; } }
                if(isDarkness) { darknessTimer -= delta; if(darknessTimer <= 1.0) document.getElementById('curseOverlay').classList.add('pulse'); if(darknessTimer <= 0) { isDarkness = false; scene.fog.density = 0.003; scene.fog.color.setHex(0x020105); document.getElementById('curseOverlay').style.opacity = 0; document.getElementById('curseOverlay').classList.remove('pulse'); if(lanternOn) playerLight.distance = 120; } }
                if (isHoldingMouse && currentWeapon === 'gun' && !isSilenced) { gunFireTimer -= delta; if(gunFireTimer <= 0) { fireGun(); gunFireTimer = isFrenzy ? 0.05 : 0.12; } }
                if (dashCooldown > 0) { dashCooldown -= delta; updateSkillUI(); } if (abilityCooldown > 0) { abilityCooldown -= delta; updateSkillUI(); }
                if (runnerTimer > 0) runnerTimer -= delta; if (orbSpeedTimer > 0) { orbSpeedTimer -= delta; if(orbSpeedTimer<=0) document.getElementById('speedOverlay').style.opacity = 0; }

                velocity.x -= velocity.x * 10.0 * delta; velocity.z -= velocity.z * 10.0 * delta; velocity.y -= 9.8 * 55.0 * delta; 
                direction.z = Number(moveForward) - Number(moveBackward); direction.x = Number(moveRight) - Number(moveLeft); direction.normalize();

                let finalSpeed = baseSpeed * phaseMultiplier; if (isFrenzy) finalSpeed *= 1.8; if (runnerTimer > 0) finalSpeed *= 2.5; if (orbSpeedTimer > 0) finalSpeed *= 1.3;
                if (moveForward || moveBackward) velocity.z -= direction.z * finalSpeed * delta; if (moveLeft || moveRight) velocity.x -= direction.x * finalSpeed * delta;
                let aimMulti = isAiming ? 0.4 : 1.0; controls.moveRight(-velocity.x * delta * aimMulti); controls.moveForward(-velocity.z * delta * aimMulti); 
                
                let targetY = 10;
                for(let p of platforms) {
                    let w = p.geometry.parameters.width/2; let d = p.geometry.parameters.depth/2; let h = p.geometry.parameters.height/2;
                    if(Math.abs(pos.x - p.position.x) < w + 2 && Math.abs(pos.z - p.position.z) < d + 2) {
                        let platTop = p.position.y + h + 10; if(pos.y >= platTop - 2 && velocity.y <= 0) { targetY = platTop; break; }
                    }
                }
                pos.y += (velocity.y * delta); if (pos.y <= targetY) { velocity.y = 0; pos.y = targetY; canJump = true; } else { canJump = false; }
                if(pos.x > mapSize/2-5) pos.x = mapSize/2-5; if(pos.x < -mapSize/2+5) pos.x = -mapSize/2+5; if(pos.z > mapSize/2-5) pos.z = mapSize/2-5; if(pos.z < -mapSize/2+5) pos.z = -mapSize/2+5;

                updateBoss(delta, time);

                for (let i = particles.length - 1; i >= 0; i--) { let p = particles[i]; p.mesh.position.addScaledVector(p.vel, delta); p.life -= delta; if(p.life <= 0) { scene.remove(p.mesh); particles.splice(i, 1); } }
                for (let i = minions.length - 1; i >= 0; i--) { let m = minions[i]; m.lookAt(pos.x, m.position.y, pos.z); m.translateZ(m.userData.speed * delta); for (let j = 0; j < minions.length; j++) { if(i === j) continue; let dist = m.position.distanceTo(minions[j].position); if(dist < 12) { let push = new THREE.Vector3().subVectors(m.position, minions[j].position).normalize().multiplyScalar(15 * delta); m.position.add(push); } } if (m.position.distanceTo(pos) < 9.0) { takeDamage(m.userData.damage); scene.remove(m); minions.splice(i, 1); } }
                for (let i = orbs.length - 1; i >= 0; i--) { let o = orbs[i]; o.rotation.y += 2*delta; o.rotation.x += 1*delta; o.position.y += Math.sin(time*0.005)*0.05; o.userData.life -= delta; if(o.position.distanceTo(pos) < 8.0) { playSound('orb'); if(o.userData.type === 'heal') { playerHealth = Math.min(maxPlayerHealth, playerHealth + 30); document.getElementById('healOverlay').style.opacity = 1; setTimeout(()=>document.getElementById('healOverlay').style.opacity = 0, 300); updateUI(); } else if(o.userData.type === 'speed') { orbSpeedTimer = 8.0; document.getElementById('speedOverlay').style.opacity = 1; } else if(o.userData.type === 'damage') { takeDamage(40); } scene.remove(o); orbs.splice(i, 1); continue; } if(o.userData.life <= 0) { scene.remove(o); orbs.splice(i, 1); } }
                for (let i = activePortals.length - 1; i >= 0; i--) { let p = activePortals[i]; p.rotation.z += delta; if(p.position.distanceTo(pos) < 15.0) { playSound('portal'); playerHealth = Math.min(maxPlayerHealth, playerHealth + (maxPlayerHealth*0.25)); updateUI(); document.getElementById('healOverlay').style.opacity = 1; setTimeout(()=>document.getElementById('healOverlay').style.opacity = 0, 500); controls.getObject().position.set((Math.random()-0.5)*700, 50, (Math.random()-0.5)*700); scene.remove(p); activePortals.splice(i, 1); } }
                for (let i = badPortals.length - 1; i >= 0; i--) { let p = badPortals[i]; p.timer -= delta; p.mesh.rotation.z += 3 * delta; if (p.timer <= 0) { spawnMinion(p.mesh.position); scene.remove(p.mesh); badPortals.splice(i, 1); } }
                for (let i = projectiles.length - 1; i >= 0; i--) { let p = projectiles[i]; if (p.userData.isHoming) { const targetDir = new THREE.Vector3().subVectors(pos, p.position).normalize(); p.position.addScaledVector(targetDir, p.userData.speed * delta); } else { p.position.addScaledVector(p.userData.direction, p.userData.speed * delta); } p.userData.life -= delta; if (p.position.distanceTo(pos) < 7.0) { takeDamage(25); scene.remove(p); projectiles.splice(i, 1); continue; } if (p.userData.life <= 0) { scene.remove(p); projectiles.splice(i, 1); } }
                for (let i = shockwaves.length - 1; i >= 0; i--) { let sw = shockwaves[i]; sw.userData.radius += sw.userData.speed * delta; sw.children[0].scale.set(sw.userData.radius, sw.userData.radius, 1); let dist = sw.position.distanceTo(new THREE.Vector3(pos.x, 0, pos.z)); if (dist > sw.userData.radius * 0.8 && dist < sw.userData.radius * 1.2 && pos.y < targetY+5) { takeDamage(30); scene.remove(sw); shockwaves.splice(i, 1); continue; } if (sw.userData.radius > sw.userData.maxRadius) { scene.remove(sw); shockwaves.splice(i, 1); } }
                for (let i = lasers.length - 1; i >= 0; i--) { lasers[i].life -= delta; if(lasers[i].mesh.material.opacity !== undefined) lasers[i].mesh.material.opacity -= delta * 1.5; if (lasers[i].life <= 0) { scene.remove(lasers[i].mesh); lasers.splice(i, 1); } }
            }
            renderer.render(scene, camera); prevTime = time;
        }
        animate();
        window.addEventListener('resize', () => { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); });
    </script>
