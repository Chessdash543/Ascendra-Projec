        function fireGun() {
            if (isReloading || ammo <= 0 || isSilenced) return;
            ammo--; playSound('shoot');
            if(!isAiming) { targetGunPos.z = -0.8; targetGunRotX = 0.3; setTimeout(() => { targetGunPos.z = gunBasePos.z; targetGunRotX = 0; }, 60); }
            let baseGunDamage = isFrenzy ? 200 : 120;
