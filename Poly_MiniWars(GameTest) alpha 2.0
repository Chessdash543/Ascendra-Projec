<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brotato Clone - Sobrevivência Infinita</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
    overflow:hidden;
    background:#111;
    font-family:Arial,sans-serif;
    color:white;
    user-select:none;
}
canvas{
    display:block;
    background:#181818;
    cursor:crosshair;
}
#menu,#upgradeMenu,#gameOver{
    position:absolute;
    inset:0;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    background:rgba(0,0,0,.85);
    z-index:10;
}
.hidden{display:none!important;}
button{
    padding:15px 30px;
    font-size:20px;
    cursor:pointer;
    margin:10px;
    border:none;
    border-radius:10px;
    background:#2a9df4;
    color:white;
    font-weight:bold;
    transition:transform .1s;
}
button:hover{
    transform:scale(1.05);
    background:#3aaeff;
}
h1{margin-bottom:20px;}
.choice{
    width:380px;
    text-align:left;
    background:#222;
    border:2px solid #2a9df4;
}
.choice:hover{
    background:#2a9df4;
}
.choice b{
    display:block;
    font-size:20px;
    margin-bottom:4px;
}
.choice span{
    font-size:13px;
    opacity:.8;
    font-weight:normal;
}
#ui{
    position:absolute;
    top:10px;
    left:10px;
    z-index:5;
    font-size:18px;
    line-height:1.5;
    text-shadow:1px 1px 2px #000;
    pointer-events:none;
}
#hpBarWrap{
    width:220px;
    height:18px;
    background:#400;
    border:2px solid #800;
    border-radius:4px;
    overflow:hidden;
    margin-top:4px;
}
#hpBarFill{
    height:100%;
    background:linear-gradient(90deg,#ff3b3b,#ff8a3b);
    width:100%;
    transition:width .1s;
}
#waveInfo{
    position:absolute;
    top:10px;
    right:10px;
    z-index:5;
    font-size:18px;
    text-align:right;
    text-shadow:1px 1px 2px #000;
    pointer-events:none;
}
#idleWarning{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    font-size:42px;
    font-weight:bold;
    color:#ff3b3b;
    text-shadow:0 0 10px #ff0000,2px 2px 4px #000;
    z-index:6;
    pointer-events:none;
    display:none;
    animation:pulse .4s infinite alternate;
}
@keyframes pulse{
    from{opacity:1;transform:translate(-50%,-50%) scale(1);}
    to{opacity:.5;transform:translate(-50%,-50%) scale(1.1);}
}
#bossUI{
    position:absolute;
    top:10px;
    left:50%;
    transform:translateX(-50%);
    width:50%;
    min-width:300px;
    z-index:5;
    text-align:center;
    display:none;
}
#bossName{
    font-size:20px;
    font-weight:bold;
    color:#ff4dff;
    text-shadow:1px 1px 3px #000;
    margin-bottom:4px;
    letter-spacing:1px;
}
#bossHpWrap{
    width:100%;
    height:20px;
    background:#222;
    border:2px solid #ff4dff;
    border-radius:4px;
    overflow:hidden;
}
#bossHpFill{
    height:100%;
    background:linear-gradient(90deg,#a900ff,#ff4dff);
    width:100%;
    transition:width .1s;
}
</style>
</head>
<body>


<div id="ui">
    <div>⭐ Nível: <span id="lvlTxt">1</span> | XP: <span id="xpTxt">0/30</span></div>
    <div id="hpBarWrap"><div id="hpBarFill"></div></div>
    <div>💀 Pontos: <span id="scoreTxt">0</span></div>
</div>

<div id="waveInfo"></div>

<div id="idleWarning">⚠ MOVA-SE! ⚠</div>

<div id="bossUI">
    <div id="bossName">???</div>
    <div id="bossHpWrap"><div id="bossHpFill"></div></div>
</div>


<div id="menu">
    <h1>BROTATO SURVIVAL</h1>
    <p>WASD para mover</p>
    <p>Mire com o mouse — o tiro segue o cursor</p>
    <p>Fique parado por muito tempo e você sofre dano!</p>
    <p>Sobreviva a 15 ondas, derrote 3 mini-chefes e enfrente o CHEFÃO</p>
    <br>
    <button id="startBtn">JOGAR</button>
</div>


<div id="upgradeMenu" class="hidden">
    <h1>ESCOLHA UM UPGRADE</h1>
    <div id="choices"></div>
</div>


<div id="gameOver" class="hidden">
    <h1 id="gameOverTitle">GAME OVER</h1>
    <h2 id="finalScore"></h2>
    <h3 id="bestScore"></h3>
    <button onclick="location.reload()">JOGAR NOVAMENTE</button>
</div>


<canvas id="game"></canvas>


<script>


const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");


function resize(){
 canvas.width=window.innerWidth;
 canvas.height=window.innerHeight;
}
resize();
window.addEventListener("resize",resize);


let gameStarted=false;
let paused=false;


/* ---------- referências de UI ---------- */
const hpBarFill=document.getElementById("hpBarFill");
const lvlTxt=document.getElementById("lvlTxt");
const xpTxt=document.getElementById("xpTxt");
const scoreTxt=document.getElementById("scoreTxt");
const waveInfo=document.getElementById("waveInfo");
const idleWarning=document.getElementById("idleWarning");
const bossUI=document.getElementById("bossUI");
const bossName=document.getElementById("bossName");
const bossHpFill=document.getElementById("bossHpFill");


/* ---------- mouse ---------- */
const mouse={x:0,y:0};
canvas.addEventListener("mousemove",e=>{
 mouse.x=e.clientX;
 mouse.y=e.clientY;
});


const player={
 x:0,
 y:0,
 r:20,
 speed:4,
 maxHp:100,
 hp:100,
 damage:15,
 fireRate:400,
 bulletSpeed:8,
 xp:0,
 level:1,
 xpNeeded:30,
 regen:0,
 bullets:1,
 shieldHp:0,
 shieldMax:0
};


function resetPlayer(){
 player.x=canvas.width/2;
 player.y=canvas.height/2;
}


resetPlayer();


let enemies=[];
let bullets=[];
let enemyBullets=[];
let particles=[];
let lasers=[]; // ataques de laser do boss (área temporária)
let score=0;


const keys={};


addEventListener("keydown",e=>{
 keys[e.key.toLowerCase()]=true;
});
addEventListener("keyup",e=>{
 keys[e.key.toLowerCase()]=false;
});


document.getElementById("startBtn").onclick=()=>{
 gameStarted=true;
 document.getElementById("menu").classList.add("hidden");
};


/* =======================================================
   SISTEMA DE ONDAS
   15 ondas de inimigos comuns -> 3 miniboss (um por vez,
   intervalado por pequenas ondas) -> Boss final
======================================================= */
const TOTAL_WAVES=15;
const MINIBOSS_COUNT=3;

const wave={
 number:0,            // onda atual de inimigos comuns (1..15)
 phase:"normal",       // normal | miniboss | bossIntro | boss | cleared
 minibossesDefeated:0,
 enemiesToSpawn:0,
 enemiesAlive:0,
 spawnTimer:0,
 spawnInterval:1000,
 waitingNextWave:false
};

function enemiesRemainingOnField(){
 return enemies.length;
}

function startNextWave(){

 if(wave.phase==="cleared") return;

 if(wave.number<TOTAL_WAVES){
  wave.number++;
  wave.phase="normal";
  wave.enemiesToSpawn=4+Math.floor(wave.number*1.6);
  wave.enemiesAlive=0;
  wave.spawnTimer=0;
  wave.spawnInterval=Math.max(280,950-wave.number*40);
  wave.waitingNextWave=false;
 }
 else if(wave.minibossesDefeated<MINIBOSS_COUNT){
  wave.phase="miniboss";
  wave.waitingNextWave=false;
  spawnMiniboss();
 }
 else{
  wave.phase="bossIntro";
  wave.waitingNextWave=false;
  startBossIntro();
 }
}

function updateWaveUI(){
 if(wave.phase==="normal"){
  waveInfo.innerHTML=`🌊 Onda ${wave.number}/${TOTAL_WAVES}<br>Inimigos restantes: ${enemiesRemainingOnField()+Math.max(0,wave.enemiesToSpawn)}`;
 }
 else if(wave.phase==="miniboss"){
  waveInfo.innerHTML=`👁️ Mini-Chefe ${wave.minibossesDefeated+1}/${MINIBOSS_COUNT}`;
 }
 else if(wave.phase==="bossIntro"||wave.phase==="boss"){
  waveInfo.innerHTML=`☠️ CHEFE FINAL`;
 }
 else if(wave.phase==="cleared"){
  waveInfo.innerHTML=`🏆 VOCÊ VENCEU!`;
 }
}

/* lógica de progressão a cada frame */
function updateWaveLogic(dt){

 if(wave.phase==="normal"){

  if(wave.enemiesToSpawn>0){
   wave.spawnTimer+=dt;
   if(wave.spawnTimer>=wave.spawnInterval){
    wave.spawnTimer=0;
    wave.enemiesToSpawn--;
    spawnRandomCommonEnemy();
   }
  }
  else if(enemies.length===0 && !wave.waitingNextWave){
   wave.waitingNextWave=true;
   setTimeout(()=>{
    if(gameStarted) startNextWave();
   },1200);
  }
 }
 else if(wave.phase==="miniboss"){
  if(enemies.length===0 && !wave.waitingNextWave){
   wave.waitingNextWave=true;
   wave.minibossesDefeated++;
   setTimeout(()=>{
    if(gameStarted) startNextWave();
   },1500);
  }
 }
 else if(wave.phase==="boss"){
  if(enemies.length===0 && !wave.waitingNextWave){
   wave.waitingNextWave=true;
   wave.phase="cleared";
   setTimeout(()=>{
    if(gameStarted) victory();
   },800);
  }
 }

 updateWaveUI();
}


/* =======================================================
   INIMIGOS COMUNS: bola, triângulo, quadrado
======================================================= */

function spawnPosOffscreen(){
 let side=Math.floor(Math.random()*4);
 let x,y;
 if(side===0){ x=Math.random()*canvas.width; y=-40; }
 else if(side===1){ x=canvas.width+40; y=Math.random()*canvas.height; }
 else if(side===2){ x=Math.random()*canvas.width; y=canvas.height+40; }
 else{ x=-40; y=Math.random()*canvas.height; }
 return {x,y};
}

function spawnRandomCommonEnemy(){
 const pos=spawnPosOffscreen();
 const roll=Math.random();
 let type;
 if(roll<0.4) type="ball";
 else if(roll<0.75) type="triangle";
 else type="square";

 enemies.push(new Enemy(pos.x,pos.y,type));
 wave.enemiesAlive++;
}

function spawnMiniboss(){
 const pos=spawnPosOffscreen();
 enemies.push(new Enemy(pos.x,pos.y,"miniboss"));
}


class Enemy{
 constructor(x,y,type){
  this.x=x;
  this.y=y;
  this.type=type; // ball | triangle | square | miniboss

  const scale=1+score*0.0008; // leve scaling com progressão

  if(type==="ball"){
   this.r=16;
   this.maxHp=Math.floor(28*scale);
   this.speed=1+Math.random()*0.6;
   this.damage=8;
   this.shootCooldown=1400+Math.random()*600;
   this.shootTimer=this.shootCooldown*Math.random();
   this.preferredDist=260;
  }
  else if(type==="triangle"){
   this.r=14;
   this.maxHp=Math.floor(20*scale);
   this.speed=2.6+Math.random()*0.8;
   this.damage=14;
  }
  else if(type==="square"){
   this.r=18;
   this.maxHp=Math.floor(40*scale);
   this.speed=0.9+Math.random()*0.4;
   this.damage=6;
   this.shieldRadius=140;
   this.shieldAmount=0.5; // reduz dano recebido de aliados próximos em 50%
  }
  else if(type==="miniboss"){
   this.r=42;
   this.maxHp=Math.floor(420*scale);
   this.speed=1.1;
   this.damage=18;
   this.name="Sentinela Anelar";
  }

  this.hp=this.maxHp;
  this.flashTime=0;
  this.angle=0;
 }

 takeDamage(dmg){
  // quadrados dão escudo a aliados próximos (reduz dano recebido)
  let finalDmg=dmg;
  enemies.forEach(other=>{
   if(other!==this && other.type==="square"){
    const d=Math.hypot(other.x-this.x,other.y-this.y);
    if(d<other.shieldRadius){
     finalDmg*=(1-other.shieldAmount);
    }
   }
  });
  this.hp-=finalDmg;
  this.flashTime=8;
  return finalDmg;
 }

 update(dt){

  this.angle+=0.05;
  if(this.flashTime>0) this.flashTime--;

  const dx=player.x-this.x;
  const dy=player.y-this.y;
  const d=Math.hypot(dx,dy)||1;

  if(this.type==="ball"){
   // mantém distância e atira
   if(d>this.preferredDist){
    this.x+=dx/d*this.speed;
    this.y+=dy/d*this.speed;
   }
   else if(d<this.preferredDist-40){
    this.x-=dx/d*this.speed;
    this.y-=dy/d*this.speed;
   }
   this.shootTimer+=dt;
   if(this.shootTimer>=this.shootCooldown){
    this.shootTimer=0;
    const angle=Math.atan2(dy,dx);
    enemyBullets.push(new EnemyBullet(
     this.x,this.y,
     Math.cos(angle)*5,
     Math.sin(angle)*5,
     this.damage
    ));
   }
  }
  else if(this.type==="square"){
   // avança lento, fica perto dos aliados se possível
   this.x+=dx/d*this.speed;
   this.y+=dy/d*this.speed;
   if(d<player.r+this.r){
    applyContactDamage(this.damage);
   }
  }
  else{
   // triangle e miniboss avançam diretamente
   this.x+=dx/d*this.speed;
   this.y+=dy/d*this.speed;
   if(d<player.r+this.r){
    applyContactDamage(this.damage);
   }
  }
 }

 draw(){
  ctx.save();
  ctx.translate(this.x,this.y);

  let color;
  if(this.type==="ball") color="#ff5050";
  else if(this.type==="triangle") color="#ffae42";
  else if(this.type==="square") color="#7ed6ff";
  else color="#c850ff";

  if(this.flashTime>0) color="white";

  ctx.fillStyle=color;

  if(this.type==="ball"){
   ctx.beginPath();
   ctx.arc(0,0,this.r,0,Math.PI*2);
   ctx.fill();
  }
  else if(this.type==="triangle"){
   ctx.rotate(this.angle);
   ctx.beginPath();
   ctx.moveTo(0,-this.r);
   ctx.lineTo(this.r*0.87,this.r*0.5);
   ctx.lineTo(-this.r*0.87,this.r*0.5);
   ctx.closePath();
   ctx.fill();
  }
  else if(this.type==="square"){
   ctx.rotate(this.angle*0.5);
   ctx.fillRect(-this.r,-this.r,this.r*2,this.r*2);
   // raio do escudo
   ctx.strokeStyle="rgba(126,214,255,0.25)";
   ctx.lineWidth=2;
   ctx.beginPath();
   ctx.arc(0,0,this.shieldRadius,0,Math.PI*2);
   ctx.stroke();
  }
  else if(this.type==="miniboss"){
   // anel / circunferência
   ctx.lineWidth=10;
   ctx.strokeStyle=color;
   ctx.beginPath();
   ctx.arc(0,0,this.r,0,Math.PI*2);
   ctx.stroke();
   ctx.fillStyle="rgba(200,80,255,0.15)";
   ctx.beginPath();
   ctx.arc(0,0,this.r-10,0,Math.PI*2);
   ctx.fill();
  }

  ctx.restore();

  // barra de vida (exceto miniboss, que tem UI própria opcional, mas mantemos simples acima dele também)
  ctx.fillStyle="red";
  ctx.fillRect(this.x-this.r,this.y-this.r-14,this.r*2,5);
  ctx.fillStyle="lime";
  ctx.fillRect(this.x-this.r,this.y-this.r-14,(this.hp/this.maxHp)*(this.r*2),5);

  if(this.type==="miniboss"){
   ctx.fillStyle="white";
   ctx.font="13px Arial";
   ctx.textAlign="center";
   ctx.fillText(this.name,this.x,this.y-this.r-20);
  }
 }
}


class EnemyBullet{
 constructor(x,y,vx,vy,damage){
  this.x=x;this.y=y;this.vx=vx;this.vy=vy;this.r=6;this.damage=damage;
 }
 update(){ this.x+=this.vx; this.y+=this.vy; }
 draw(){
  ctx.fillStyle="#ff3b3b";
  ctx.beginPath();
  ctx.arc(this.x,this.y,this.r,0,Math.PI*2);
  ctx.fill();
 }
}


/* =======================================================
   BOSS FINAL
======================================================= */
const BOSS_NAME="REI CARMESIM, O DEVORADOR";

const boss={
 obj:null,
 phase:"idle", // idle | grab | laser360 | superlaser | cooldown
 phaseTimer:0,
 attackCooldown:0,
 grab:{active:false,timer:0,duration:1400,targetX:0,targetY:0},
 superLaser:{active:false,timer:0,angle:0,charging:true,chargeDuration:1000,fireDuration:1200},
};

class Boss{
 constructor(x,y){
  this.x=x;
  this.y=y;
  this.r=70;
  this.maxHp=6000;
  this.hp=this.maxHp;
  this.speed=0.7;
  this.damage=22;
  this.flashTime=0;
  this.angle=0;
 }
 takeDamage(dmg){
  this.hp-=dmg;
  this.flashTime=8;
 }
 update(dt){
  this.angle+=0.01;
  if(this.flashTime>0) this.flashTime--;

  // movimentação lenta, exceto durante grab
  if(boss.phase!=="grab"){
   const dx=player.x-this.x;
   const dy=player.y-this.y;
   const d=Math.hypot(dx,dy)||1;
   if(d>220){
    this.x+=dx/d*this.speed;
    this.y+=dy/d*this.speed;
   }
   const dContact=Math.hypot(dx,dy);
   if(dContact<player.r+this.r){
    applyContactDamage(this.damage*0.4);
   }
  }
 }
 draw(){
  ctx.save();
  ctx.translate(this.x,this.y);
  ctx.rotate(this.angle);

  ctx.fillStyle=this.flashTime>0?"white":"#7a0030";
  ctx.beginPath();
  for(let i=0;i<8;i++){
   const a=(Math.PI*2/8)*i;
   const rad=i%2===0?this.r:this.r*0.7;
   const px=Math.cos(a)*rad;
   const py=Math.sin(a)*rad;
   if(i===0) ctx.moveTo(px,py); else ctx.lineTo(px,py);
  }
  ctx.closePath();
  ctx.fill();

  ctx.fillStyle="rgba(255,0,80,0.3)";
  ctx.beginPath();
  ctx.arc(0,0,this.r*0.5,0,Math.PI*2);
  ctx.fill();

  ctx.restore();
 }
}


function startBossIntro(){
 wave.phase="bossIntro";
 bossUI.style.display="block";
 bossName.textContent=BOSS_NAME;
 waveInfo.innerHTML="☠️ O CHEFE ESTÁ CHEGANDO...";

 setTimeout(()=>{
  if(!gameStarted) return;
  const b=new Boss(canvas.width/2,-150);
  boss.obj=b;
  enemies.push(b); // tratado em conjunto para colisão de balas, mas update/draw próprios
  wave.phase="boss";
  boss.phase="cooldown";
  boss.attackCooldown=1500;
 },2200);
}

function updateBossAI(dt){
 if(!boss.obj || wave.phase!=="boss") return;
 const b=boss.obj;

 if(boss.phase==="cooldown"){
  boss.attackCooldown-=dt;
  if(boss.attackCooldown<=0){
   chooseBossAttack();
  }
 }
 else if(boss.phase==="grab"){
  boss.grab.timer+=dt;
  const t=Math.min(1,boss.grab.timer/boss.grab.duration);
  // puxa o jogador para o boss
  player.x+= (b.x-player.x)*0.04;
  player.y+= (b.y-player.y)*0.04;
  if(t>=1){
   applyContactDamage(30);
   boss.phase="cooldown";
   boss.attackCooldown=1800;
  }
 }
 else if(boss.phase==="laser360"){
  boss.phaseTimer+=dt;
  // dano em anel se jogador estiver dentro do raio crescente
  const ringR=lasers.find(l=>l.kind==="ring");
  if(ringR){
   const d=Math.hypot(player.x-b.x,player.y-b.y);
   if(Math.abs(d-ringR.radius)<ringR.thickness/2){
    applyContactDamage(0.6);
   }
   ringR.radius+=ringR.speed;
   if(ringR.radius>Math.max(canvas.width,canvas.height)){
    lasers=lasers.filter(l=>l!==ringR);
    boss.phase="cooldown";
    boss.attackCooldown=2000;
   }
  }
 }
 else if(boss.phase==="superlaser"){
  const sl=boss.superLaser;
  sl.timer+=dt;

  if(sl.charging){
   if(sl.timer>=sl.chargeDuration){
    sl.charging=false;
    sl.timer=0;
   }
  }
  else{
   // disparando: checa se jogador está na linha do laser
   if(playerInLaserBeam(b,sl.angle)){
    applyContactDamage(1.1);
   }
   if(sl.timer>=sl.fireDuration){
    sl.active=false;
    boss.phase="cooldown";
    boss.attackCooldown=2200;
   }
  }
 }
}

function playerInLaserBeam(b,angle){
 const dx=player.x-b.x;
 const dy=player.y-b.y;
 const dist=Math.hypot(dx,dy);
 const beamAngle=Math.atan2(dy,dx);
 let diff=Math.abs(beamAngle-angle);
 if(diff>Math.PI) diff=Math.PI*2-diff;
 const angularWidth=0.12; // largura do feixe
 return diff<angularWidth && dist<Math.max(canvas.width,canvas.height);
}

function chooseBossAttack(){
 const r=Math.random();
 const b=boss.obj;

 if(r<0.34){
  boss.phase="grab";
  boss.grab.timer=0;
 }
 else if(r<0.67){
  boss.phase="laser360";
  boss.phaseTimer=0;
  lasers.push({kind:"ring",x:b.x,y:b.y,radius:b.r+10,speed:6,thickness:24});
 }
 else{
  boss.phase="superlaser";
  boss.superLaser.timer=0;
  boss.superLaser.charging=true;
  boss.superLaser.angle=Math.atan2(player.y-b.y,player.x-b.x);
 }
}

function drawBossExtras(){
 if(!boss.obj) return;
 const b=boss.obj;

 // anel de laser 360
 lasers.forEach(l=>{
  if(l.kind==="ring"){
   ctx.strokeStyle="rgba(255,40,40,0.8)";
   ctx.lineWidth=l.thickness;
   ctx.beginPath();
   ctx.arc(l.x,l.y,l.radius,0,Math.PI*2);
   ctx.stroke();
  }
 });

 // super laser
 if(boss.phase==="superlaser"){
  const sl=boss.superLaser;
  const len=Math.max(canvas.width,canvas.height)*1.5;
  if(sl.charging){
   ctx.strokeStyle="rgba(255,255,255,0.5)";
   ctx.lineWidth=3;
  }
  else{
   ctx.strokeStyle="rgba(255,0,0,0.95)";
   ctx.lineWidth=18;
  }
  ctx.beginPath();
  ctx.moveTo(b.x,b.y);
  ctx.lineTo(
   b.x+Math.cos(sl.angle)*len,
   b.y+Math.sin(sl.angle)*len
  );
  ctx.stroke();
 }

 // aviso de grab
 if(boss.phase==="grab"){
  ctx.fillStyle="rgba(255,0,80,0.15)";
  ctx.beginPath();
  ctx.arc(b.x,b.y,300,0,Math.PI*2);
  ctx.fill();
 }
}


/* =======================================================
   COMBATE DO JOGADOR
======================================================= */

function nearestTargetToMouse(){
 // dispara em direção ao mouse sempre (independente de inimigo)
 return {x:mouse.x,y:mouse.y};
}

class Bullet{
 constructor(x,y,vx,vy){
  this.x=x;this.y=y;this.vx=vx;this.vy=vy;this.r=5;
 }
 update(){ this.x+=this.vx; this.y+=this.vy; }
 draw(){
  ctx.fillStyle="gold";
  ctx.beginPath();
  ctx.arc(this.x,this.y,this.r,0,Math.PI*2);
  ctx.fill();
 }
}

let fireTimer=0;

function tryFire(dt){
 fireTimer+=dt;
 if(fireTimer<player.fireRate) return;
 fireTimer=0;

 const target=nearestTargetToMouse();
 const baseAngle=Math.atan2(target.y-player.y,target.x-player.x);

 for(let i=0;i<player.bullets;i++){
  const spread=(i-(player.bullets-1)/2)*0.12;
  const angle=baseAngle+spread;
  bullets.push(new Bullet(
   player.x,player.y,
   Math.cos(angle)*player.bulletSpeed,
   Math.sin(angle)*player.bulletSpeed
  ));
 }
}


/* =======================================================
   MECÂNICA DE FICAR PARADO (idle damage)
======================================================= */
const IDLE_LIMIT=3000; // 3s
const IDLE_WARNING_AT=2000; // aviso após 2s parado
let idleTimer=0;
let lastX=player.x,lastY=player.y;

function updateIdle(dt){
 const moved=Math.hypot(player.x-lastX,player.y-lastY)>0.5;

 if(moved){
  idleTimer=0;
  idleWarning.style.display="none";
 }
 else{
  idleTimer+=dt;
  if(idleTimer>=IDLE_WARNING_AT){
   idleWarning.style.display="block";
  }
  if(idleTimer>=IDLE_LIMIT){
   applyContactDamage(0.35); // dano contínuo enquanto parado além do limite
  }
 }

 lastX=player.x;
 lastY=player.y;
}


/* =======================================================
   DANO / ESCUDO DO JOGADOR
======================================================= */
function applyContactDamage(amount){
 if(player.shieldHp>0){
  const absorbed=Math.min(player.shieldHp,amount);
  player.shieldHp-=absorbed;
  amount-=absorbed;
 }
 if(amount>0) player.hp-=amount;
}


/* =======================================================
   UPGRADES
======================================================= */
const upgrades=[
 { name:"+20 Vida Máxima", desc:"Aumenta sua vida máxima e cura 20.",
   apply(){ player.maxHp+=20; player.hp+=20; } },
 { name:"+5 Dano", desc:"Suas balas causam mais dano.",
   apply(){ player.damage+=5; } },
 { name:"+10% Velocidade", desc:"Movimente-se mais rápido.",
   apply(){ player.speed+=0.5; } },
 { name:"+1 Projétil", desc:"Dispara um projétil adicional por rajada.",
   apply(){ player.bullets++; } },
 { name:"+20% Velocidade de Tiro", desc:"Reduz o intervalo entre tiros.",
   apply(){ player.fireRate=Math.max(80,player.fireRate*0.8); } },
 { name:"+0.5 Regeneração", desc:"Recupera vida lentamente com o tempo.",
   apply(){ player.regen+=0.5; } },
 { name:"+30 Escudo", desc:"Ganha um escudo que absorve dano antes da vida.",
   apply(){ player.shieldMax+=30; player.shieldHp+=30; } },
];

function levelUp(){

 paused=true;

 player.level++;
 player.xp=0;
 player.xpNeeded=Math.floor(player.xpNeeded*1.35);

 const menu=document.getElementById("upgradeMenu");
 const choices=document.getElementById("choices");

 choices.innerHTML="";
 menu.classList.remove("hidden");

 let selected=[];
 while(selected.length<3){
  let u=upgrades[Math.floor(Math.random()*upgrades.length)];
  if(!selected.includes(u)) selected.push(u);
 }

 selected.forEach(up=>{
  const btn=document.createElement("button");
  btn.className="choice";
  btn.innerHTML=`<b>${up.name}</b><span>${up.desc}</span>`;
  btn.onclick=()=>{
   up.apply();
   menu.classList.add("hidden");
   paused=false;
  };
  choices.appendChild(btn);
 });
}


/* =======================================================
   GAME OVER / VITÓRIA
======================================================= */
function gameOver(){
 gameStarted=false;
 let best=parseInt(localStorage.getItem("brotato_best")||0);
 if(score>best){ best=score; localStorage.setItem("brotato_best",best); }

 document.getElementById("gameOverTitle").textContent="GAME OVER";
 document.getElementById("finalScore").textContent="Pontuação: "+score;
 document.getElementById("bestScore").textContent="Recorde: "+best;
 document.getElementById("gameOver").classList.remove("hidden");
}

function victory(){
 gameStarted=false;
 let best=parseInt(localStorage.getItem("brotato_best")||0);
 if(score>best){ best=score; localStorage.setItem("brotato_best",best); }

 document.getElementById("gameOverTitle").textContent="VITÓRIA! 🏆";
 document.getElementById("finalScore").textContent="Pontuação: "+score;
 document.getElementById("bestScore").textContent="Recorde: "+best;
 document.getElementById("gameOver").classList.remove("hidden");
}


/* =======================================================
   LOOP PRINCIPAL
======================================================= */
let lastTime=performance.now();

function update(dt){

 if(keys["w"]) player.y-=player.speed;
 if(keys["s"]) player.y+=player.speed;
 if(keys["a"]) player.x-=player.speed;
 if(keys["d"]) player.x+=player.speed;

 player.x=Math.max(0,Math.min(canvas.width,player.x));
 player.y=Math.max(0,Math.min(canvas.height,player.y));

 player.hp=Math.min(player.maxHp,player.hp+player.regen*0.01);
 if(player.shieldMax>0 && player.shieldHp<player.shieldMax){
  player.shieldHp=Math.min(player.shieldMax,player.shieldHp+0.05);
 }

 updateIdle(dt);
 tryFire(dt);

 // balas do jogador
 bullets.forEach((b,bi)=>{
  b.update();

  let bulletConsumed=false;

  // bala vs inimigos comuns / miniboss (boss é tratado separadamente abaixo)
  enemies.forEach((e,ei)=>{
   if(bulletConsumed || e instanceof Boss) return;

   const d=Math.hypot(b.x-e.x,b.y-e.y);
   if(d<b.r+e.r){

    e.takeDamage(player.damage);
    bullets.splice(bi,1);
    bulletConsumed=true;

    for(let i=0;i<8;i++) particles.push(new Particle(e.x,e.y,"orange"));

    if(e.hp<=0){
     score+=e.type==="miniboss"?80:1;
     player.xp+=e.type==="miniboss"?60:8;

     for(let i=0;i<25;i++) particles.push(new Particle(e.x,e.y,"yellow"));
     enemies.splice(ei,1);
    }
   }
  });

  // bala vs boss
  if(!bulletConsumed && boss.obj){
   const b2=boss.obj;
   const d=Math.hypot(b.x-b2.x,b.y-b2.y);
   if(d<b.r+b2.r){
    b2.takeDamage(player.damage);
    bullets.splice(bi,1);
    for(let i=0;i<8;i++) particles.push(new Particle(b2.x,b2.y,"#ff66cc"));

    if(b2.hp<=0){
     score+=500;
     player.xp+=300;
     for(let i=0;i<60;i++) particles.push(new Particle(b2.x,b2.y,"#ff66cc"));
     enemies=enemies.filter(en=>en!==b2);
     boss.obj=null;
     boss.phase="idle";
     lasers=[];
     bossUI.style.display="none";
    }
   }
  }
 });

 // balas inimigas
 enemyBullets.forEach((b,bi)=>{
  b.update();
  const d=Math.hypot(b.x-player.x,b.y-player.y);
  if(d<b.r+player.r){
   applyContactDamage(b.damage);
   enemyBullets.splice(bi,1);
  }
  if(b.x<-50||b.x>canvas.width+50||b.y<-50||b.y>canvas.height+50){
   enemyBullets.splice(bi,1);
  }
 });

 // inimigos comuns / miniboss
 enemies.forEach(e=>{
  if(e instanceof Boss) return; // boss tratado separadamente
  e.update(dt);
 });

 // boss
 if(boss.obj){
  boss.obj.update(dt);
  updateBossAI(dt);
 }

 particles.forEach((p,i)=>{
  p.update();
  if(p.life<=0) particles.splice(i,1);
 });

 if(player.xp>=player.xpNeeded){
  levelUp();
 }

 if(player.hp<=0){
  gameOver();
 }

 if(wave.phase==="boss"){
  bossUI.style.display="block";
  if(boss.obj){
   bossHpFill.style.width=(boss.obj.hp/boss.obj.maxHp*100)+"%";
  }
 }

 updateWaveLogic(dt);
}

class Particle{
 constructor(x,y,color){
  this.x=x;this.y=y;
  this.vx=(Math.random()-0.5)*6;
  this.vy=(Math.random()-0.5)*6;
  this.life=40;
  this.color=color;
 }
 update(){ this.x+=this.vx; this.y+=this.vy; this.life--; }
 draw(){
  ctx.globalAlpha=this.life/40;
  ctx.fillStyle=this.color;
  ctx.fillRect(this.x,this.y,4,4);
  ctx.globalAlpha=1;
 }
}


function draw(){

 ctx.clearRect(0,0,canvas.width,canvas.height);

 drawBossExtras();

 // escudo do jogador (visual)
 if(player.shieldHp>0){
  ctx.strokeStyle="rgba(120,200,255,0.7)";
  ctx.lineWidth=3;
  ctx.beginPath();
  ctx.arc(player.x,player.y,player.r+8,0,Math.PI*2);
  ctx.stroke();
 }

 ctx.fillStyle="#2a9df4";
 ctx.beginPath();
 ctx.arc(player.x,player.y,player.r,0,Math.PI*2);
 ctx.fill();

 // linha de mira sutil até o mouse
 ctx.strokeStyle="rgba(255,255,255,0.15)";
 ctx.lineWidth=1;
 ctx.beginPath();
 ctx.moveTo(player.x,player.y);
 ctx.lineTo(mouse.x,mouse.y);
 ctx.stroke();

 bullets.forEach(b=>b.draw());
 enemyBullets.forEach(b=>b.draw());
 enemies.forEach(e=>e.draw());
 particles.forEach(p=>p.draw());

 // UI textual
 lvlTxt.textContent=player.level;
 xpTxt.textContent=`${player.xp}/${player.xpNeeded}`;
 scoreTxt.textContent=score;
 hpBarFill.style.width=Math.max(0,player.hp/player.maxHp*100)+"%";
}


function loop(now){

 requestAnimationFrame(loop);

 const dt=Math.min(50,now-lastTime); // cap pra evitar saltos grandes
 lastTime=now;

 if(!gameStarted||paused) return;

 update(dt);
 draw();
}


/* inicia a primeira onda quando o jogo começa */
const originalStart=document.getElementById("startBtn").onclick;
document.getElementById("startBtn").onclick=()=>{
 gameStarted=true;
 document.getElementById("menu").classList.add("hidden");
 startNextWave();
};


requestAnimationFrame(loop);


</script>
</body>
</html>
